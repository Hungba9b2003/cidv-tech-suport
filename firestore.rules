rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Hàm hỗ trợ
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    // Mặc định từ chối tất cả
    match /{document=**} {
      allow read, write: if false;
    }

    // Danh mục: Cho phép mọi người đọc, chỉ admin (sau này) hoặc người bán mới được sửa
    // Hiện tại cho phép đọc công khai để khách hàng xem
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // Tạm thời khóa ghi từ client để bảo vệ dữ liệu gốc
    }

    // Videos: Cho phép mọi người đọc, chỉ admin mới được sửa
    match /videos/{videoId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
