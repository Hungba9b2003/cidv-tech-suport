{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Loại máy móc (ví dụ: máy cắt, máy hàn)",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Tên loại máy" },
        "icon": { "type": "string", "description": "Tên icon từ lucide-react" },
        "description": { "type": "string", "description": "Mô tả ngắn gọn" }
      },
      "required": ["name"]
    },
    "Video": {
      "title": "Video",
      "description": "Video hướng dẫn căn chỉnh máy",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string", "description": "ID của danh mục máy" },
        "workshopId": { "type": "string", "description": "ID của xưởng (nếu có)" },
        "isPrivate": { "type": "boolean", "description": "Video riêng tư cho xưởng" },
        "accessCode": { "type": "string", "description": "Mã truy cập" },
        "title": { "type": "string", "description": "Tiêu đề video" },
        "description": { "type": "string", "description": "Mô tả chi tiết các bước" },
        "videoUrl": { "type": "string", "description": "Link video (Youtube/Direct)" },
        "thumbnailUrl": { "type": "string", "description": "Ảnh hiển thị trước" },
        "duration": { "type": "string", "description": "Thời lượng video" },
        "steps": {
          "type": "array",
          "description": "Các mốc thời gian quan trọng trong video"
        }
      },
      "required": ["categoryId", "title", "videoUrl"]
    },
    "News": {
      "title": "News",
      "description": "Bài viết tin tức, cẩm nang",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Tiêu đề bài viết" },
        "excerpt": { "type": "string", "description": "Mô tả ngắn" },
        "content": { "type": "string", "description": "Nội dung bài viết" },
        "imageUrl": { "type": "string", "description": "Ảnh đại diện" },
        "publishDate": { "type": "string", "format": "date-time" },
        "author": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title", "content", "category"]
    }
  },
  "firestore": {
    "categories": {
      "schema": "Category",
      "description": "Bộ sưu tập các loại máy móc"
    },
    "videos": {
      "schema": "Video",
      "description": "Bộ sưu tập các video hướng dẫn"
    },
    "news": {
      "schema": "News",
      "description": "Bộ sưu tập các bài viết tin tức"
    }
  }
}
